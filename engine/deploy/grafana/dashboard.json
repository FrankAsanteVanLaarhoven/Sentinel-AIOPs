{
  "title": "Sentinel - Golden Signals & SLO",
  "panels": [
    { "type": "timeseries", "title": "Request rate (RPS) by service",
      "targets": [ { "expr": "sum by (service_name) (rate(http_requests_total[1m]))" } ] },
    { "type": "timeseries", "title": "Error ratio by service",
      "targets": [ { "expr": "job:http_error_ratio:rate5m" } ] },
    { "type": "timeseries", "title": "p95 latency (ms)",
      "targets": [ { "expr": "histogram_quantile(0.95, sum by (le,service_name) (rate(http_request_duration_ms_bucket[5m])))" } ] },
    { "type": "stat", "title": "Error-budget burn rate",
      "targets": [ { "expr": "job:http_error_ratio:rate5m / 0.01" } ] }
  ],
  "schemaVersion": 39, "version": 1
}
